# Password for nuxt-auth-utils (minimum 32 characters)
NUXT_SESSION_PASSWORD=
# Comma-separated list of passwords (each password identifies a unique user)
USERPASSWORDS=
# Vercel AI gateway key
AI_GATEWAY_API_KEY=
# Postgres database url
DATABASE_URL=
# S3-compatible object storage endpoint
NUXT_S3_ENDPOINT=
# S3-compatible object storage region (use auto for Tigris)
NUXT_S3_REGION=auto
# S3-compatible object storage bucket
NUXT_S3_BUCKET=
# S3-compatible object storage access key
NUXT_S3_ACCESS_KEY_ID=
# S3-compatible object storage secret key
NUXT_S3_SECRET_ACCESS_KEY=
